# IndiBrew Vendor Risk Monitor — Environment Variables
# Copy to .env and edit as needed. All values are optional (safe defaults apply).

# ── Risk Thresholds ──────────────────────────────────────────────────────────
VENDOR_RISK_SCORE_HIGH=7.0
VENDOR_DELAY_DAYS_HIGH=15
VENDOR_SCORE_CRITICAL=9.5
INCIDENT_MIN_IMPACT_INR=100000
EMPLOYEE_MIN_INCIDENTS=3

# ── Analysis Settings ────────────────────────────────────────────────────────
TREND_WINDOW_DAYS=30

# ── Organisation ─────────────────────────────────────────────────────────────
ORG_NAME=IndiBrew Business Services Hyderabad GCC

# ── File Paths ────────────────────────────────────────────────────────────────
DATA_DIR=data/sample
OUTPUT_DIR=reports
